{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Onest))/i]",
        "message": "Font not provided by the design system. Available: Onest."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--pd-bg",
      "--pd-bg-2",
      "--pd-dark",
      "--pd-dark-2",
      "--pd-dark-line",
      "--pd-display",
      "--pd-faint",
      "--pd-font",
      "--pd-ink",
      "--pd-ink-2",
      "--pd-line",
      "--pd-muted",
      "--pd-navy",
      "--pd-on-dark",
      "--pd-on-dark-mut",
      "--pd-r-lg",
      "--pd-r-md",
      "--pd-r-pill",
      "--pd-r-sm",
      "--pd-r-xl",
      "--pd-red",
      "--pd-red-deep",
      "--pd-red-soft",
      "--pd-s1",
      "--pd-s2",
      "--pd-s3",
      "--pd-s4",
      "--pd-s5",
      "--pd-s6",
      "--pd-s7",
      "--pd-s8",
      "--pd-s9",
      "--pd-shadow-lg",
      "--pd-shadow-md",
      "--pd-shadow-red",
      "--pd-shadow-sm",
      "--pd-white"
    ],
    "tokenKinds": {
      "--pd-red": "color",
      "--pd-red-deep": "color",
      "--pd-red-soft": "color",
      "--pd-navy": "color",
      "--pd-ink": "color",
      "--pd-ink-2": "color",
      "--pd-muted": "color",
      "--pd-faint": "color",
      "--pd-line": "color",
      "--pd-bg": "color",
      "--pd-bg-2": "color",
      "--pd-white": "color",
      "--pd-dark": "color",
      "--pd-dark-2": "color",
      "--pd-dark-line": "color",
      "--pd-on-dark": "color",
      "--pd-on-dark-mut": "color",
      "--pd-r-sm": "spacing",
      "--pd-r-md": "spacing",
      "--pd-r-lg": "spacing",
      "--pd-r-xl": "spacing",
      "--pd-r-pill": "spacing",
      "--pd-shadow-sm": "shadow",
      "--pd-shadow-md": "shadow",
      "--pd-shadow-lg": "shadow",
      "--pd-shadow-red": "shadow",
      "--pd-s1": "spacing",
      "--pd-s2": "spacing",
      "--pd-s3": "spacing",
      "--pd-s4": "spacing",
      "--pd-s5": "spacing",
      "--pd-s6": "spacing",
      "--pd-s7": "spacing",
      "--pd-s8": "spacing",
      "--pd-s9": "spacing",
      "--pd-font": "font",
      "--pd-display": "font"
    },
    "fontFamilies": [
      "Onest"
    ]
  }
}